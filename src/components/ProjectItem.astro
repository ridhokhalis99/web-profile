---
import Github from "../icons/Github.astro";

export interface Props {
  title: string;
  description: string;
  techStack: string[];
  githubLink: string;
  liveLink?: string;
}

const { title, description, techStack, githubLink, liveLink } = Astro.props;
---

<div class="project">
  <div class="project-header">
    <h3 class="primary-mono">Featured Project</h3>
    <div class="project-links">
      <a href={githubLink} target="_blank" aria-label="View source on GitHub">
        <Github />
      </a>
    </div>
  </div>
  <a class="project-title" href={liveLink ?? githubLink} target="_blank"
    >{title}</a
  >
  <p class="project-description">{description}</p>
  <div class="project-footer">
    <div class="tech-stack">
      {techStack.map((tech) => <span class="tech">{tech}</span>)}
    </div>
  </div>
</div>

<style lang="scss">
  .project {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    border: 1px solid rgba(100, 255, 218, 0.2);
    border-radius: 16px;
    padding: 48px;
    background: linear-gradient(
        135deg,
        rgba(17, 34, 64, 0.95),
        rgba(17, 34, 64, 0.8)
      )
      var(--light-navy);
    box-shadow: 0 15px 40px -20px var(--navy-shadow);
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition: border-color 0.3s ease, transform 0.3s ease,
      box-shadow 0.3s ease;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle at top right,
        rgba(100, 255, 218, 0.15),
        transparent 60%
      );
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: -1;
    }

    &:hover,
    &:focus-within {
      border-color: var(--primary-color);
      transform: translateY(-6px);
      box-shadow: 0 25px 45px -25px var(--navy-shadow);

      &::after {
        opacity: 1;
      }
    }

    @media screen and (max-width: 1024px) {
      padding: 40px;
    }

    @media screen and (max-width: 480px) {
      padding: 28px;
    }

    .project-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;

      h3 {
        letter-spacing: 0.08em;
      }
    }

    .project-title {
      color: var(--lightest-slate);
      font-size: clamp(26px, 4vw, 32px);
      font-weight: 600;
      line-height: 1.2;
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        color: var(--primary-color);
      }
    }

    .project-description {
      color: var(--slate);
      text-align: left;
      line-height: 1.6;
    }

    .project-footer {
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 16px;
      flex-wrap: wrap;
    }

    .tech-stack {
      display: flex;
      column-gap: 16px;
      row-gap: 12px;
      flex-wrap: wrap;

      .tech {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--light-slate);
        background-color: rgba(148, 163, 184, 0.08);
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.2);
      }
    }

    .project-links {
      display: flex;
      align-items: center;

      a {
        color: var(--lightest-slate);
        transition: all 0.3s ease-in-out;
        width: 28px;

        &:hover {
          color: var(--primary-color);
          transform: translateY(-4px);
        }
      }
    }
  }
</style>
