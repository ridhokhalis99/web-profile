---
import SectionHeader from "../components/SectionHeader.astro";
import contentFeeds from "../../public/data/contentFeeds";
type Platform = "linkedin" | "medium" | "tiktok";

const platformMeta: Record<Platform, { label: string; badge: string; cta: string }> = {
  linkedin: {
    label: "LinkedIn",
    badge: "Update",
    cta: "View on LinkedIn",
  },
  medium: {
    label: "Medium",
    badge: "Article",
    cta: "Read on Medium",
  },
  tiktok: {
    label: "TikTok",
    badge: "Video",
    cta: "Watch on TikTok",
  },
};

const gridItems = (Object.keys(contentFeeds) as Platform[]).flatMap(
  (platform) =>
    contentFeeds[platform].map((item) => ({
      ...item,
      platform,
      ...platformMeta[platform],
    }))
);

const truncate = (text: string, limit = 160) =>
  text.length > limit ? `${text.slice(0, limit).trimEnd()}...` : text;

const getDescription = (item: (typeof gridItems)[number]) => {
  return item.description ? truncate(item.description) : "";
};

---

<section class="hidden" id="content">
  <div class="section-content">
    <SectionHeader index={3} title="Content & Highlights" />
    <div class="content-grid">
      {
        gridItems.map((item) => (
          <a
            class={`content-card platform-${item.platform}`}
            href={item.url}
            target="_blank"
          >
            <div class="card-tag">
              <span class={`platform-chip platform-${item.platform}`}>
                {item.label}
              </span>
              <span class="badge">{item.badge}</span>
            </div>
            {item.image && (
              <div class="card-media">
                <img src={item.image} alt={item.title} loading="lazy" />
              </div>
            )}
            <h4>{item.title}</h4>
            <p class="description">{getDescription(item)}</p>
            <span class="card-cta">{item.cta}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  section#content {
    margin-top: 80px;
  }

  section {
    .section-content {
      .content-grid {
        margin-top: 32px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;

        @media screen and (max-width: 1024px) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        @media screen and (max-width: 640px) {
          grid-template-columns: 1fr;
        }
      }

      .content-card {
        text-decoration: none;
        color: inherit;
        border: 1px solid rgba(148, 163, 184, 0.3);
        border-radius: 18px;
        padding: 24px;
        background: rgba(17, 34, 64, 0.9);
        box-shadow: 0 20px 35px -30px var(--navy-shadow);
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 260px;
        transition: border-color 0.2s ease, transform 0.2s ease;

        &:hover {
          border-color: var(--primary-color);
          transform: translateY(-4px);
        }

        .card-tag {
          display: flex;
          justify-content: space-between;
          align-items: center;
          font-family: var(--mono);
          font-size: 12px;
          color: var(--light-slate);
          gap: 12px;

          .badge {
            border: 1px solid rgba(148, 163, 184, 0.6);
            border-radius: 999px;
            padding: 2px 10px;
            font-size: 11px;
          }

          .platform-chip {
            display: inline-flex;
            color: var(--lightest-slate);
            letter-spacing: 0.04em;
          }
        }

        .card-media {
          width: 100%;
          border-radius: 12px;
          overflow: hidden;
          border: 1px solid rgba(148, 163, 184, 0.15);
          background-color: rgba(10, 25, 47, 0.6);
          display: flex;
          align-items: center;
          justify-content: center;

          img {
            width: 100%;
            max-height: 220px;
            object-fit: contain;
            background-color: rgba(10, 25, 47, 0.3);
            display: block;
          }
        }

        h4 {
          color: var(--lightest-slate);
          font-size: 20px;
          line-height: 1.3;
        }

        .description {
          color: var(--slate);
          line-height: 1.5;
          flex: 1;
        }

        .card-cta {
          font-family: var(--mono);
          color: var(--primary-color);
          width: fit-content;
          font-size: 13px;

          &:hover {
            opacity: 0.8;
          }
        }
      }

      .platform-linkedin {
        background: linear-gradient(
            135deg,
            rgba(14, 118, 168, 0.12),
            rgba(17, 34, 64, 0.9)
          ),
          rgba(17, 34, 64, 0.9);
      }

      .platform-medium {
        background: linear-gradient(
            135deg,
            rgba(100, 255, 218, 0.12),
            rgba(17, 34, 64, 0.9)
          ),
          rgba(17, 34, 64, 0.9);
      }

      .platform-tiktok {
        background: linear-gradient(
            135deg,
            rgba(255, 44, 90, 0.12),
            rgba(17, 34, 64, 0.9)
          ),
          rgba(17, 34, 64, 0.9);
      }
    }
  }
</style>
